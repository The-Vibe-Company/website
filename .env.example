# Payload CMS
PAYLOAD_SECRET=your-payload-secret-here
DATABASE_URL=postgresql://user:password@localhost:5432/thevibecompany
CONTENT_WRITE_TOKEN=choose-a-long-random-token-for-the-write-api

# Vercel Blob Storage (REQUIRED in production — media uploads fail without this)
BLOB_READ_WRITE_TOKEN=

# Environment
NODE_ENV=development

# Vercel Deploy Hook (triggers rebuild when CMS content changes)
VERCEL_DEPLOY_HOOK_URL=

# PostHog (frontend analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
